<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="aznut_mrp_quality_video.MediaRecordDialog">
        <div role="dialog"
            t-attf-class="modal video_dialog"
            tabindex="-1"
            data-backdrop="static"
            data-keyboard="false"
            t-att-id="_.uniqueId('modal_')"
            aria-hidden="true"
            >
            <div class="modal-dialog media_recorder_dialog">
                <div class="modal-content">
                    <header t-if="renderHeader" class="modal-header">
                        <h4 class="modal-title"><t t-out="title"/><span class="o_subtitle text-muted small" t-out="subtitle"/></h4>
                    </header>
                    <main class="modal-body d-flex flex-column">
                        <ul class="nav nav-tabs mb-3" id="pills-tab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <a aria-controls="pills_recording" role="tab" data-toggle="tab" class="nav-link active" href="#pills_recording">
                                    Recording
                                </a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a id="preview_pill" aria-controls="pills_preview" role="tab" data-toggle="tab" class="nav-link disabled" href="#pills_preview">
                                    Preview
                                </a>
                            </li>
                        </ul>
                        <div class="tab-content video_tabs">
                            <div class="tab-pane fade show active" id="pills_recording" role="tabpanel">
                                <select class="form-select" id="selectCamera" aria-label="Default select example">
                                    <option seleted="true" value="">Select camera</option>
                                </select>

                                <t t-call="aznut_mrp_quality_video.VideoBlock"/>

                                <div class="record_btn_wrap invisible">
                                    <div class="record_btn">
                                        <input type="checkbox" id="start_stop_recording"/>
                                        <label for="start_stop_recording"></label>
                                        <div class="time">
                                            <div class="h_m"></div>
                                            <div class="s_ms"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="fail_buttons fail_buttons-hidden">
                                    <a id="save_btn" href="#" class="btn btn-primary">Save</a>
                                    <a id="retake_btn" href="#" class="btn btn-warning">Retake</a>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="pills_preview" role="tabpanel">
                                <div id="videoReviewContainer" class="mt-3"></div>
                                <div class="review_result d-flex align-items-center justify-content-between">
                                    <a id="pass_btn" href="#" class="btn btn-primary">Pass</a>
                                    <a id="fail_btn" href="#" class="btn btn-danger">Fail</a>
                                </div>
                            </div>
                        </div>
                    </main>
                    <footer t-if="renderFooter" class="modal-footer"/>
                </div>
            </div>
        </div>
    </t>

    <t t-name="aznut_mrp_quality_video.VideoBlock">
        <div id="video_block" t-attf-class="{{!permissionsGranted || !is_device_selected ? 'video_hold' : ''}}">
            <t t-if="permissionsGranted">
                <t t-if="is_device_selected">
                    <video id="quality_video" width="100%" autoplay="" playsinline="" muted="true"/>
                    <img id="current_snapshot" class="w-100 d-none"/>
                </t>
                <t t-else="">
                    <span class="danger_text">Please select a Camera</span>
                </t>
            </t>
            <t t-else="">
                <i class="fa fa-exclamation-circle danger_icon" aria-hidden="true"></i>
                <span class="danger_text">Access to devices are blocked</span>
                <br/><br/>
                <span class="regular_text">
                    Please allow your web browser to<br/> access your devices.
                </span>
            </t>
        </div>
    </t>
</templates>