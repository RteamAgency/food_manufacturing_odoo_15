<?xml version="1.0" ?>
<odoo>
    <data>
        <record id="seq_complaint_claim" model="ir.sequence">
            <field name="name">Complaint Claim</field>
            <field name="code">complaint.claim</field>
            <field name="prefix">CMP</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_recall" model="ir.sequence">
            <field name="name">Recall</field>
            <field name="code">recall.recall</field>
            <field name="prefix">RC</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
