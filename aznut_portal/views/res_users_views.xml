<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_users_form_simple_modif" model="ir.ui.view">
        <field name="name">aznut_portal.res.users.preferences.form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Zoom &amp; Calendly &amp; Fireflies Integration">
                    <group string="Zoom Settings">
                        <group>
                            <field name="zoom_client"/>
                            <field name="zoom_client_secret" password="1"/>
                            <button type="object" class='btn-primary' name="action_zoom_authenticate"
                                    string="Authenticate"/>
                        </group>
                        <group>
                            <field name="zoom_redirect_link"/>
                            <field name="zoom_access_token_expiry"/>
                            <button type="object" class='btn-primary' name="action_zoom_refresh_token"
                                    string="Refresh"/>
                        </group>
                    </group>
                    <group string="Calendly Settings">
                        <group>
                            <field name="calendly_link"/>
                        </group>
                    </group>
                    <group string="Fireflies">
                        <group>
                            <field name="fireflies_token" password="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_users_form" model="ir.ui.view">
        <field name="name">aznut_portal.res.users.form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Brand Access" attrs="{'invisible':[('share','=',False)]}">
                    <group>
                        <group>
                            <field name="allowed_brands_ids" invisible="1"/>
                            <field name="user_brands_ids" widget="many2many_tags"
                                   domain="[('id','in',allowed_brands_ids)]"
                                   options="{'no_create_edit':True,'no_create':True,'no_open':True}"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
