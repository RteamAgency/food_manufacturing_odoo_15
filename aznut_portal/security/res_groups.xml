<odoo>
    <data noupdate="1">
        <function name="write" model="ir.model.data">
            <function name="search" model="ir.model.data">
                <value eval="[('module', '=', 'website_sale'), ('name', '=', 'product_template_public')]"/>
            </function>
            <value eval="{'noupdate': False}"/>
        </function>

        <record id="website_sale.product_template_public" model="ir.rule">
            <field name="domain_force">[('website_published', '=', True), ("sale_ok", "=", True),('brand_id','in',user.user_brands_ids.ids)]</field>
        </record>

        <function name="write" model="ir.model.data">
            <function name="search" model="ir.model.data">
                <value eval="[('module', '=', 'website_sale'), ('name', '=', 'product_template_public')]"/>
            </function>
            <value eval="{'noupdate': True}"/>
        </function>
    </data>
</odoo>
