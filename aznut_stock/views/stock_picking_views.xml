<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_picking_edi_tree_inherited" model="ir.ui.view">
            <field name="model">stock.picking</field>
            <field name="name">stock.picking.edi.tree.inherited</field>
            <field name="inherit_id" ref="stock.vpicktree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="stock_source_tags" widget="stock_source_tags"/>
                </xpath>
            </field>
        </record>

        <record id="aznut_picking_view_kanban_inherited" model="ir.ui.view">
            <field name="name">aznut.stock.picking.view.kanban.inherited</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.stock_picking_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('o_kanban_record_bottom')]" position="after">
                    <div>
                        <field name="stock_source_tags" nolabel="1" widget="stock_source_tags"/>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="aznut_view_picking_form_inherited" model="ir.ui.view">
            <field name="model">stock.picking</field>
            <field name="name">aznut.view.picking.form.inherited</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <field name="can_report_send" invisible="1"/>
                    <button name="action_send_transfer_report"
                            attrs="{'invisible':['|',('can_report_send','=', False),('state', '!=', 'done')]}"
                            string="Send report"
                            type="object"
                            class="oe_highlight"/>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="before">
                    <field name="reserved_from_stock" invisible="1"/>
                </xpath>
            </field>
        </record>

        <record id="view_stock_move_line_detailed_operation_tree" model="ir.ui.view">
            <field name="model">stock.move.line</field>
            <field name="name">aznut_stock.stock.move.line.operations.tree</field>
            <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="inside">
                    <field name="reserved_from_stock"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
