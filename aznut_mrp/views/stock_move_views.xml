<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_stock_move_operations">
        <field name="name">aznut_mrp.stock.move.operations.form</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_stock_move_operations"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@special='save']" position="after">
                <button string="Distribute Reserve" name="action_open_move_reserve_wizard" type="object"
                        class="btn btn-secondary"/>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="view_stock_move_operations_raw">
        <field name="name">aznut_mrp.stock.move.operations.raw.form</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="mrp.view_stock_move_operations_raw"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_line_ids']" position="after">
                <field name="can_edit" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='move_line_ids']" position="attributes">
                <attribute name="attrs">{
                    'readonly': ['|', '|', ('state', '=', 'cancel'), ('can_edit', '=', False), '&amp;',
                                 ('state', '=', 'done'), ('is_locked', '=', True)]}</attribute>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="view_move_line_tree">
        <field name="name">aznut_mrp.stock.move.line.tree</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='result_package_id']" position="after">
                <field name="show_upload_lot_image_button" invisible="1"/>
                <button type="object"
                        attrs="{'invisible':[('show_upload_lot_image_button','=',False)]}"
                        string="Upload Image" class="btn btn-primary" name="action_upload_lot_image"/>
            </xpath>
        </field>
    </record>


</odoo>
