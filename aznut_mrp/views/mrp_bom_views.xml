<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="mrp_bom_form_view_inherited" model="ir.ui.view">
            <field name="name">mrp.bom.form.inherited</field>
            <field name="model">mrp.bom</field>
            <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='bom_line_ids']//field[@name='product_uom_id']" position="after">
                    <field name="pump_uom" attrs="{'invisible':[('pump_uom','&lt;=',0)]}"/>
                </xpath>
                <xpath expr="//field[@name='bom_line_ids']" position="after">
                    <div class="row">
                        <div class="col-5 offset-7 col-md-3 offset-md-9"
                                style="padding:0px 25px !important;">
                            <div class="total border-top" style="padding:0px 5x">
                                <table class="w-100">
                                    <tbody>
                                        <tr>
                                            <td class="o_td_label">
                                                <span class="o_form_label o_tax_total_label">
                                                    Total Quantity lb:
                                                </span>
                                            </td>
                                            <td style="text-align:end;">
                                                <div>
                                                    <span name="Total Quantity"
                                                            style="white-space: nowrap; font-weight: bold;">
                                                        <field name="total_qty_lb"/>
                                                    </span>
                                                </div>
                                            </td>
                                        </tr>
                                        <tr class="border-top">
                                            <td class="o_td_label">
                                                <span class="o_form_label o_tax_total_label">
                                                    Total Quantity Units:
                                                </span>
                                            </td>
                                            <td style="text-align:end;">
                                                <span name="Total Cost"
                                                        style="white-space: nowrap; font-weight: bold;">
                                                    <field name="total_qty_units"/>
                                                </span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
