<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="set_scheduled_date_wizard_form" model="ir.ui.view">
        <field name="name">aznut_mrp.set.scheduled.date.wizard.form</field>
        <field name="model">set.scheduled.date.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="scheduled_date"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button special="cancel" data-hotkey="z" string='Cancel' class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
