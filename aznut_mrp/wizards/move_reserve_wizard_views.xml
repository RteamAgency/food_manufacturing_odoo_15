<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="move_reserve_wizard_form" model="ir.ui.view">
        <field name="name">aznut_mrp.move.reserve.wizard.form</field>
        <field name="model">move.reserve.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="move_reserve_wizard_line_ids" nolabel="1">
                            <tree editable="top">
                                <field name="product_id"/>
                                <field name="lot_id" domain="[('product_id','=',product_id)]"/>
                                <field name="location_id"/>
                                <field name="owner_id"/>
                                <field name="package_id"/>
                                <field name="new_quantity"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button special="cancel" data-hotkey="z" string='Cancel' class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
