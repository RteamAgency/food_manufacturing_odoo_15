<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="confirm_production_quantity_wizard_form" model="ir.ui.view">
        <field name="name">aznut_mrp.confirm.production.quantity.form</field>
        <field name="model">confirm.production.quantity.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="wizard_production_id"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="actual_quantity"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button special="cancel" data-hotkey="z" string='Cancel' class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
