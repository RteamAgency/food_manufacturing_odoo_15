<odoo>
    <record id="maintenance_request_recurrence_wizard_form" model="ir.ui.view">
        <field name="name">maintenance_request_recurrence.form</field>
        <field name="model">maintenance.request.recurrence.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Recurrence Period">
                            <field name="repeat_day"/>
                            <field name="repeat_number"/>
                            <field name="repeat_period"/>
                        </group>
                        <group string="Recurrence Main Settings">
                            <field name="maintenance_request_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="next_date"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_validate" string="Create Recurrence" type="object" class="btn-primary"/>
                    <button special="cancel" data-hotkey="z" string='Cancel' class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
