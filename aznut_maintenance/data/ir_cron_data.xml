<odoo>
    <data>
        <record id="maintenance_request_recurrence_cron" model="ir.cron">
            <field name="name">Maintenance: Create New Requests</field>
            <field name="model_id" ref="model_maintenance_request_recurrence"/>
            <field name="state">code</field>
            <field name="numbercall">-1</field>
            <field name="code">model._cron_create_maintenance_request()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>
    </data>
</odoo>
