<odoo>
    <data noupdate="1">
        <record id="group_calculator_procurement" model="res.groups">
            <field name="name">Calculator Procurement</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="category_aznut_calculator" model="ir.module.category">
            <field name="name">Calculator</field>
            <field name="sequence">60</field>
        </record>

        <record id="group_calculator_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="aznut_calculator.category_aznut_calculator"/>
        </record>

        <record id="group_calculator_manager" model="res.groups">
            <field name="name">Calculator Manager</field>
            <field name="implied_ids" eval="[(4, ref('aznut_calculator.group_calculator_user'))]"/>
            <field name="category_id" ref="aznut_calculator.category_aznut_calculator"/>
        </record>

        <record id="group_calculator_administrator" model="res.groups">
            <field name="name">Calculator Administrator</field>
            <field name="category_id" ref="aznut_calculator.category_aznut_calculator"/>
            <field name="implied_ids" eval="[(4, ref('aznut_calculator.group_calculator_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_calculator_salesperson" model="res.groups">
            <field name="name">Calculator Salesperson</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('aznut_calculator.group_calculator_user')),(4, ref('base.group_partner_manager'))]"/>
        </record>

        <record id="aznut_calculator_user_rule" model="ir.rule">
            <field name="name">Allow calculator user see only his quotes</field>
            <field name="model_id" ref="aznut_calculator.model_main_product_calculator"/>
            <field name="domain_force">['|', '|', '|', '|',
                                        ('partner_id', '=', user.partner_id.id),
                                        ('lead_user_id', '=', user.id),
                                        ('procurement_partner_id', '=', user.partner_id.id),
                                        ('manufacturing_partner_id', '=', user.partner_id.id),
                                        ('create_uid', '=', user.id),
                                        ]</field>
            <field name="groups" eval="[Command.link(ref('aznut_calculator.group_calculator_user'))]"/>
        </record>

        <record id="aznut_calculator_manager_administrator_rule" model="ir.rule">
            <field name="name">Allow see and update all calculators for manager and administrator</field>
            <field name="model_id" ref="aznut_calculator.model_main_product_calculator"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('aznut_calculator.group_calculator_manager')), (4, ref('aznut_calculator.group_calculator_administrator'))]"/>
        </record>

        <record id="aznut_calculator_user_rule_powder" model="ir.rule">
            <field name="name">Allow calculator user see only his quotes</field>
            <field name="model_id" ref="aznut_calculator.model_main_powder_calculator"/>
            <field name="domain_force">['|', '|', '|', '|',
                                        ('partner_id', '=', user.partner_id.id),
                                        ('lead_user_id', '=', user.id),
                                        ('procurement_partner_id', '=', user.partner_id.id),
                                        ('manufacturing_partner_id', '=', user.partner_id.id),
                                        ('create_uid', '=', user.id),
                                        ]</field>
            <field name="groups" eval="[Command.link(ref('aznut_calculator.group_calculator_user'))]"/>
        </record>

        <record id="aznut_calculator_salesperson" model="ir.rule">
            <field name="name">Allow calculator salesperson user see only his quotes</field>
            <field name="model_id" ref="aznut_calculator.model_main_powder_calculator"/>
            <field name="domain_force">[
                ('create_uid', '=', user.id),
            ]</field>
            <field name="groups" eval="[Command.link(ref('aznut_calculator.group_calculator_user'))]"/>
        </record>

        <record id="aznut_calculator_manager_administrator_rule_powder" model="ir.rule">
            <field name="name">Allow see and update all calculators for manager and administrator</field>
            <field name="model_id" ref="aznut_calculator.model_main_powder_calculator"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('aznut_calculator.group_calculator_manager')), (4, ref('aznut_calculator.group_calculator_administrator'))]"/>
        </record>

        <record id="aznut_contacts_calculator_salesperson" model="ir.rule">
            <field name="name">Allow Calculator Salespoerson only see his partners</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">['|', ('create_uid', '=', user.id),
                                        ('is_calculator_procurement_partner', '=', True)]</field>
            <field name="groups" eval="[Command.link(ref('aznut_calculator.group_calculator_salesperson'))]"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
