<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="send_sample_test_wizard_form" model="ir.ui.view">
        <field name="name">send,sample.test.wizard.form</field>
        <field name="model">send.sample.test.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="allowed_sample_test_orders_ids" invisible="1"/>
                            <field name="sample_test_order_id" domain="[('id','in',allowed_sample_test_orders_ids)]"
                                   options="{'no_create_edit':True,'no_create':True,'no_open':True}"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Send" name="action_send" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
