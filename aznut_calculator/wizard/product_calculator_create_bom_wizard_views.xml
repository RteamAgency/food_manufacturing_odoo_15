<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_calculator_create_bom_wizard_form_view" model="ir.ui.view">
        <field name="name">product.calculator.create.bom.wizard</field>
        <field name="model">product.calculator.create.bom.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="calculator_product_category_id" invisible="1"/>
                    <field name="routes_ids" invisible="1"/>
                    <field name="suitable_wizard_calculators_ids" nolabel="1">
                        <tree editable="top" create="0" delete="0">
                            <field name="display_name"/>
                            <field name="product_tmpl_id"
                                   context="{'default_detailed_type':'product','default_tracking':'lot','default_purchase_ok':False,'categ_id':'calculator_id.calculator_product_category_id','default_categ_id':parent.calculator_product_category_id,'default_route_ids':parent.routes_ids}"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                        </tree>
                    </field>
                    <group class="bom_wiz_lines">
                        <field name="wizard_calculator_ids" widget="many2many_tags"
                               domain="[('id','in',suitable_wizard_calculators_ids)]"
                               options="{'no_create_edit':True,'no_create':True,'no_open':True}"/>
                        <field name="current_wizard_calculator_id" widget="selection_badge"
                               domain="[('id','in',wizard_calculator_ids)]"
                               attrs="{'invisible':[('wizard_calculator_ids','=',False)]}"/>
                    </group>
                    <field name="create_bom_wizard_lines_ids" widget="one2many" options="{'no_open':True}"
                           attrs="{'invisible':[('current_wizard_calculator_id','=',False)]}">
                        <tree>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button string="Confirm" name="action_confirm" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="powder_calculator_create_bom_wizard_form_view" model="ir.ui.view">
        <field name="name">powder.calculator.create.bom.wizard</field>
        <field name="model">powder.calculator.create.bom.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="suitable_wizard_calculators_ids" nolabel="1">
                        <tree editable="top" create="0" delete="0">
                            <field name="display_name"/>
                            <field name="product_tmpl_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                        </tree>
                    </field>
                    <group class="bom_wiz_lines">
                        <field name="wizard_calculator_ids" widget="many2many_tags"
                               domain="[('id','in',suitable_wizard_calculators_ids)]"
                               options="{'no_create_edit':True,'no_create':True,'no_open':True}"/>
                        <field name="current_wizard_calculator_id" widget="selection_badge"
                               domain="[('id','in',wizard_calculator_ids)]"
                               attrs="{'invisible':[('wizard_calculator_ids','=',False)]}"/>
                    </group>
                    <field name="create_bom_wizard_lines_ids" widget="one2many" options="{'no_open':True}"
                           attrs="{'invisible':[('current_wizard_calculator_id','=',False)]}">
                        <tree>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button string="Confirm" name="action_confirm" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
