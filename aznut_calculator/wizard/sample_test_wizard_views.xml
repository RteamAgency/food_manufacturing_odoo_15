<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="sample_test_wizard_form" model="ir.ui.view">
        <field name="name">sample.test.wizard.form</field>
        <field name="model">sample.test.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sample_type"/>
                            <field name="bom_id" domain="[('id','in',allowed_boms_ids)]"
                                   options="{'no_create_edit':True,'no_create':True}"/>
                            <field name="allowed_boms_ids" invisible="1"/>
                        </group>
                        <group>
                            <field name="not_allowed_test_types_ids" invisible="1"/>
                            <field name="quality_points_ids" widget="many2many_tags"
                                   domain="[('id','not in',not_allowed_test_types_ids),('product_ids','=',False)]"
                                   options="{'no_create_edit':True,'no_create':True}"/>
                            <field name="workcenter_id" domain="[('sample_test_station','=',True)]"
                                   options="{'no_create_edit':True,'no_create':True}"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Confirm" name="action_confirm" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
