<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1">
        <record id="product_calculator_settings_main" model="product.calculator.settings">
            <field name="one_batch_lb">520</field>
            <field name="name">Main Settings</field>
            <field name="base_ingredients_quantity">468</field>
            <field name="readonly_active_ingredients_quantity">52</field>
            <field name="bacteria_gram_base">10</field>
            <field name="bacteria_gram_exponent">10</field>
            <field name="auto_adjusted_base_ingredients_ids" model="product.product" eval="[(4, obj().search([('name','=','Premix Base')], limit=1).id)]"/>
        </record>

        <record id="powder_calculator_settings_main" model="powder.calculator.settings">
            <field name="scoop_grams">30</field>
            <field name="name">Main Settings</field>
            <field name="ordered_jars_number">5</field>
            <field name="packaging_materials">1</field>
            <field name="profit">2.5</field>
        </record>

        <record id="seq_product_calculator" model="ir.sequence">
            <field name="name">Chews Calculator</field>
            <field name="code">product.calculator</field>
            <field name="prefix">Quote/Chews/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_main_powder_calculator" model="ir.sequence">
            <field name="name">Main Powder Calculator</field>
            <field name="code">main.powder.calculator</field>
            <field name="prefix">Quote/Powder/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="product_uom_mg" model="uom.uom">
            <field name="name">mg</field>
            <field name="category_id" ref="uom.product_uom_categ_kgm"/>
            <field name="factor">1000000</field>
            <field name="uom_type">smaller</field>
        </record>

        <record id="support_settings_main" model="support.settings">
            <field name="name">Main Settings</field>
            <field name="gpt_text">What do you think about this feed?</field>
        </record>

        <record id="seq_ask_gpt_session" model="ir.sequence">
            <field name="name">Ask GPT Session</field>
            <field name="code">ask.gpt.session</field>
            <field name="prefix">GPT</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
