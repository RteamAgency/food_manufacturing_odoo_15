<odoo>
    <record id="ask_gpt_session_form" model="ir.ui.view">
        <field name="name">aznut_calculator.ask.gpt.session.form</field>
        <field name="model">ask.gpt.session</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <field name="chat" nolabel="1" class="w-100"/>
                    <div class="d-flex justify-content-between mb-4 mt-4">
                        <button name="action_prefill" type="object" string="Prefill" style="width: 48%"
                                class="btn-primary"/>
                        <button name="action_clear" type="object" string="Clear" style="width: 48%"
                                class="btn-primary"/>
                    </div>
                    <div class="d-flex mt-4 justify-content-between aznut-calculator-input"
                         style="vertical-align: middle;min-height: 45px!important;">
                        <field name="user_input" nolabel="1"/>
                        <button name="action_send_message" type="object" string="Send Message" class="btn-primary"
                                style="width: 23%!important;max-height: 45px"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
