<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">aznut_calculator.res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object" name="show_product_calculators" icon="fa-calculator"
                        groups="aznut_calculator.group_calculator_user">
                    <field string="Chews Calculators" name="product_calculator_count" widget="statinfo"/>
                </button>
                <button class="oe_stat_button" type="object" name="show_powder_calculators" icon="fa-calculator"
                        groups="aznut_calculator.group_calculator_user">
                    <field string="Powder Calculators" name="powder_calculator_count" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
