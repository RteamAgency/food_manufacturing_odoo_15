<odoo>
    <record id="product_template_form_view_inherit" model="ir.ui.view">
        <field name="name">aznut_calculator.product.template.common.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='uom_po_id']" position="after">
                <field name="calculator_uom_id" groups="uom.group_uom" options="{'no_create': True}"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="flavour_settings" string="Flavour Settings"
                      attrs="{'invisible':[('is_flavour','=',False)]}">
                    <field name="is_flavour" invisible="1"/>
                    <group>
                        <group>
                            <field name="flavour_quantity"/>
                        </group>
                        <group>
                            <field name="flavour_color" widget="color_picker"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
