<?xml version="1.0" ?>
<odoo>
    <data noupdate="1">
        <record id="confirm_invoice_from_opportunity_mail" model="mail.template">
            <field name="name">Aznut Sale: Confirm Invoice From Opportunity</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">New Quotation {{ object.display_name }}</field>
            <field name="email_to">orders@bpwlab.com</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 12px;">
                        Hello!
                        <br/><br/>
                        Invoice <strong t-out="ctx.get('invoice_name') or ''"/> was confirmed.
                        <br/><br/>
                        There is new sale order to check:
                        <a t-att-href="ctx.get('order_url')"
                           style="color:white;background-color: #875A7B; padding: 4px 50px 4px 50px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                            <t t-esc="object.display_name"/>
                        </a>
                        <br/><br/>
                        Thanks!
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>

        <record id="customer_report_mail" model="mail.template">
            <field name="name">Aznut Sale: Customer Report</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="subject">Laboratory Test {{ object.display_name }}</field>
            <field name="partner_to">{{ object.partner_id.id if object.sudo().partner_id.email else '' }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 12px;">
                        Hello,
                        <br/><br/>
                        Please find attached the third-party laboratory test, COA, 
                        Batch Records for your order. Kindly pay the remaining balance and 
                        schedule a pickup for shipment. As soon as we receive the payment, 
                        Your product is ready for release.
                        <br/><br/>
                        Thank you.
                        <br/>
                        Great regards!
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>
