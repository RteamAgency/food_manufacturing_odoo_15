<odoo>
    <data noupdate="0">
        <record id="category_contacts" model="ir.module.category">
            <field name="name">Contacts</field>
            <field name="sequence">70</field>
        </record>

        <record id="group_contacts_user" model="res.groups">
            <field name="name">See Own Contacts</field>
            <field name="category_id" ref="aznut_sale.category_contacts"/>
        </record>

        <record id="group_contacts_manager" model="res.groups">
            <field name="name">See All</field>
            <field name="implied_ids" eval="[(4, ref('aznut_sale.group_contacts_user'))]"/>
            <field name="category_id" ref="aznut_sale.category_contacts"/>
        </record>

        <record id="group_contacts_administrator" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="aznut_sale.category_contacts"/>
            <field name="implied_ids" eval="[(4, ref('aznut_sale.group_contacts_manager'))]"/>
        </record>

        <record model="res.groups" id="base.group_erp_manager">
            <field name="implied_ids" eval="[(4, ref('aznut_sale.group_contacts_administrator'))]"/>
        </record>

        <record model="res.groups" id="sales_team.group_sale_salesman_all_leads">
            <field name="implied_ids" eval="[(4, ref('aznut_sale.group_contacts_manager'))]"/>
        </record>

        <function name="write" model="ir.model.data">
            <function name="search" model="ir.model.data">
                <value eval="[('module', '=', 'base'), ('name', '=', 'res_partner_rule_private_employee')]" />
            </function>
            <value eval="{'noupdate': False}" />
        </function>

        <record id="base.res_partner_rule_private_employee" model="ir.rule">
            <field name="name">res.partner.rule.private.employee</field>
            <field name="active" eval="False"/>
        </record>

        <function name="write" model="ir.model.data">
            <function name="search" model="ir.model.data">
                <value eval="[('module', '=', 'base'), ('name', '=', 'res_partner_rule_private_employee')]" />
            </function>
            <value eval="{'noupdate': True}" />
        </function>

        <record id="aznut_contacts_internal_rule" model="ir.rule">
            <field name="name">Allow Internal User See His Partner</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[('id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[Command.link(ref('base.group_user'))]"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="aznut_contacts_user_rule" model="ir.rule">
            <field name="name">Allow User only see his partners</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[Command.link(ref('aznut_sale.group_contacts_user'))]"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="aznut_contacts_manager_rule" model="ir.rule">
            <field name="name">Allow Manager to see all contacts</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('aznut_sale.group_contacts_manager'))]"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="aznut_contacts_administrator_rule" model="ir.rule">
            <field name="name">Allow Administator to see all contacts</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('aznut_sale.group_contacts_administrator'))]"/>
        </record>
    </data>
</odoo>
