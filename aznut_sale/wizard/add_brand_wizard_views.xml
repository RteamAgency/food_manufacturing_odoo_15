<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="add_brand_wizard_form" model="ir.ui.view">
        <field name="name">aznut_sale.add.brand.wizard.form</field>
        <field name="model">add.brand.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="products_ids" widget="many2many_tags"/>
                        <field name="allowed_attributes_ids" invisible="1"/>
                        <field name="used_attributes_ids" invisible="1"/>
                    </group>
                    <field name="brand_line_ids">
                        <tree editable="bottom">
                            <field name="attribute_id" options="{'no_create_edit':True,'no_create':True}"
                                   domain="[('id','in',parent.allowed_attributes_ids),('id','not in',parent.used_attributes_ids)]"/>
                            <field name="value_ids" options="{'no_create_edit':True,'no_create':True}"
                                   widget="many2many_tags" domain="[('attribute_id','=',attribute_id)]"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button special="cancel" data-hotkey="z" string='Cancel' class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
