<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_quant_tree_inventory_editable" model="ir.ui.view">
        <field name="name">aznut_sale.stock.quant.inventory.tree.editable</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="sales_ids" widget="many2many_tags"/>
                <field name="sales_quantitites"/>
                <field name="show_unreserve_button" invisible="1"/>
                <button name="action_reserve"
                        type="object" string="Reserve" class="btn btn-primary mx-2 my-1"/>
                <button name="action_unreserve" attrs="{'invisible':[('show_unreserve_button','=',False)]}"
                        type="object" string="Unreserve" class="btn btn-primary mx-2 my-1"/>
            </xpath>
            <xpath expr="//field[@name='package_id']" position="after">
                <field name="reserved_quantity" string="On Hand Reserved"/>
            </xpath>
        </field>
    </record>
</odoo>