<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vendor_lead_time_report_tree" model="ir.ui.view" >
        <field name="name">view.vendor.lead.time.report.tree</field>
        <field name="model">vendor.lead.time.report</field>
        <field name="arch" type="xml">
            <tree create="0">
                <field name="product_id"/>
                <field name="date"/>
                <field name="actual_lead_time"/>
                <field name="lead_time"/>
                <field name="price"/>
            </tree>
        </field>
    </record>

    <record id="vendor_lead_time_report_search_view" model="ir.ui.view">
        <field name="name">vendor.lead.time.report.search.view</field>
        <field name="model">vendor.lead.time.report</field>
        <field name="arch" type="xml">
            <search string="Vendor Lead Time Report">
                <field name="product_id"/>
            </search>
        </field>
    </record>
</odoo>
