<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_purchaseorder_document_inherit" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//th[@name='th_quantity']" position="before">
            <th class="text-center"><strong>Packaging Quantity</strong></th>
            <th class="text-right"><strong>Packaging</strong></th>
        </xpath>
        <xpath expr="//span[@t-field='line.product_qty']/.." position="before">
            <td class="text-center">
                <span t-field="line.product_packaging_qty"/>
            </td>
            <td class="text-right">
                <span t-field="line.product_packaging_id.display_name"/>
            </td>
        </xpath>
    </template>
</odoo>
