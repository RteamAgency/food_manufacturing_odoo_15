<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record model="ir.ui.view" id="view_stock_quant_tree_inventory_editable">
        <field name="name">aznut_purchase.stock.quant.inventory.tree.editable</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_apply_inventory']" position="attributes">
                <attribute name="groups">stock.group_stock_manager,aznut_purchase.group_receiving_operator</attribute>
            </xpath>
            <xpath expr="//button[@name='stock.action_stock_inventory_adjustement_name']" position="attributes">
                <attribute name="groups">stock.group_stock_manager,aznut_purchase.group_receiving_operator</attribute>
            </xpath>
        </field>
    </record>
</odoo>
