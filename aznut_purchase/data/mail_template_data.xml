<?xml version="1.0" ?>
<odoo>
    <data>
        <record id="shipping_status_update" model="mail.template">
            <field name="name">Aznut Purchase: Shipping Status Update Main</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="subject">{{ object.display_name }} Shipping Status Update</field>
            <field name="partner_to">{{ object.partner_id.id if object.sudo().partner_id.email else ''}}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 12px;">
                        Dear <t t-esc="object.partner_id.name"/>,
                        <br/><br/>
                        We have received confirmation for the receipt date <t t-esc="object.display_name"/>.
                        <br/><br/>
                        Please provide the shipping status information, so we can schedule our production accordingly.
                        <br/><br/>
                        Thank you.
                        <br/><br/>
                        Best regards,
                        <br/>
                        BPWLAB Shipping Department
                    </p>
                </div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>
