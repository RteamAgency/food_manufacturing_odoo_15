<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="category_receiving_operator" model="ir.module.category">
            <field name="name">Receiving Operator</field>
            <field name="sequence">65</field>
        </record>

        <record id="group_purchase_super_manager" model="res.groups">
            <field name="name">Super Administrator</field>
            <field name="category_id" search="[('name', '=', 'Purchase'),('sequence', '=', 8)]"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root'))]"/>
        </record>

        <record id="group_receiving_operator" model="res.groups">
            <field name="name">Active</field>
            <field name="category_id" ref="aznut_purchase.category_receiving_operator"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user')),(4, ref('stock.group_stock_user'))]"/>
        </record>

         <record model="ir.rule" id="stock_picking_type_receiving_operator_rule">
            <field name="name">Receiving Operator: Stock Picking Type</field>
            <field name="model_id" ref="stock.model_stock_picking_type"/>
            <field name="domain_force" eval="[('id', 'in', [ref('stock.picking_type_internal'),ref('stock.picking_type_in')])]"/>
            <field name="groups" eval="[Command.link(ref('aznut_purchase.group_receiving_operator'))]"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="perm_write" eval="False"/>
        </record>

          <record model="ir.rule" id="stock_picking_receiving_operator_rule">
            <field name="name">Receiving Operator: Stock Picking</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="domain_force" eval="[('picking_type_id', 'in', [ref('stock.picking_type_internal'),ref('stock.picking_type_in')])]"/>
            <field name="groups" eval="[Command.link(ref('aznut_purchase.group_receiving_operator'))]"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="perm_write" eval="False"/>
        </record>
    </data>
</odoo>
